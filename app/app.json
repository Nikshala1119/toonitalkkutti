{
  "expo": {
    "name": "ToonTalk",
    "slug": "toonitalk",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.toonitalk.kutti"
    },
    "android": {
      "package": "app.toonitalk.kutti",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "ToonTalk uses the camera so your child can show fingers and colored objects to Kutti. Nothing is ever recorded or stored."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "ddca0210-ed92-406c-94f3-270fe46c2168"
      }
    },
    "owner": "nikshala"
  }
}
